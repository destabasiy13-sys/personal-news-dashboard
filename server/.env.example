PORT=5000
CLIENT_URL=http://localhost:5173

# use 127.0.0.1, not "localhost" - on Windows "localhost" can try a named-pipe
# connection instead of TCP, which fails against MAMP's MySQL
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=news_dashboard

SESSION_SECRET=change_this_to_a_random_string

NEWS_API_KEY=your_newsapi_key_here
